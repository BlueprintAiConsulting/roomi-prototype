rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────

    // True if the request is from an authenticated, non-anonymous user
    function isAuthenticated() {
      return request.auth != null && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    // True if the request is from the document owner
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // True if the user is a caregiver
    function isCaregiver() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'caregiver';
    }

    // True if caregiver is linked to a specific resident
    function isCaregiverFor(residentUid) {
      return isCaregiver() &&
        exists(/databases/$(database)/documents/userRoles/$(residentUid)) &&
        request.auth.uid in get(/databases/$(database)/documents/userRoles/$(residentUid)).data.get('caregiverUids', []);
    }

    // True if the user has the 'founder' role in Firestore
    // True if the user has the 'founder' (or 'admin') role in Firestore.
    // This is the server-side gate for ALL hub_* collections.
    // Mirrors the client-side FOUNDER_EMAILS list in useAuth.jsx.
    // ⚠️  Requires run-once: scripts/setFounderRoles.js (seeds roles for the 6 council members)
    function isFounder() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'founder' ||
         get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'admin');
    }

    // ─── userRoles ──────────────────────────────────────────────
    // Users can read/write their own role doc.
    // Caregivers can read resident role docs they are linked to.
    match /userRoles/{uid} {
      allow read: if isOwner(uid) || isCaregiver();
      allow create: if isOwner(uid) && isAuthenticated();
      // Only allow updating own doc; prevent self-escalation via resident path
      allow update: if isOwner(uid) && isAuthenticated();
      allow delete: if false; // never delete roles
    }

    // ─── users (profiles) ───────────────────────────────────────
    // Residents can only read/write their own profile.
    // Caregivers can read profiles of their residents.
    match /users/{uid} {
      allow read: if isOwner(uid) || isCaregiverFor(uid);
      allow write: if isOwner(uid) && request.auth != null;
    }

    // ─── conversations ──────────────────────────────────────────
    match /conversations/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         isCaregiverFor(resource.data.userId));
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ─── anchorSummaries ────────────────────────────────────────
    match /anchorSummaries/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         isCaregiverFor(resource.data.userId));
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ─── dailySummaries (cross-session memory) ────────────────
    match /dailySummaries/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         isCaregiverFor(resource.data.userId));
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ─── weeklySummaries (compressed memory) ─────────────────
    match /weeklySummaries/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         isCaregiverFor(resource.data.userId));
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ─── fcmTokens ──────────────────────────────────────────────
    // Users manage their own push tokens only.
    match /fcmTokens/{uid} {
      allow read, write: if isOwner(uid) && isAuthenticated();
    }

    // ─── notifPrefs ─────────────────────────────────────────────
    // Notification preferences — per-user, owner-only.
    // Used by usePushNotifications.js for quiet hours + event toggles.
    match /notifPrefs/{uid} {
      allow read, write: if isOwner(uid) && isAuthenticated();
    }

    // ─── analytics (Phase 1) ────────────────────────────────────
    match /analytics/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ─── feedback (Phase 1) ─────────────────────────────────────
    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ─── safetyEvents (Phase 1) ─────────────────────────────────
    match /safetyEvents/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ─── systemPrompts (Phase 2B) ───────────────────────────────
    match /systemPrompts/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    // ─── inviteCodes (Phase 2D) ─────────────────────────────────
    match /inviteCodes/{docId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null &&
        request.resource.data.used == true &&
        request.resource.data.usedBy == request.auth.uid;
      allow create, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════
    // Founder Hub Collections — isFounder() required for all access
    // Non-founders get DENIED at the Firestore level (defense-in-depth
    // on top of the client-side RBAC in useAuth.jsx / Navbar.jsx).
    // ═══════════════════════════════════════════════════════════════

    match /hub_documents/{docId} {
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if isFounder();
    }

    match /hub_decisions/{docId} {
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if isFounder();
    }

    match /hub_meetings/{docId} {
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if isFounder();
    }

    match /hub_funding/{docId} {
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if isFounder();
    }

    match /hub_pilots/{docId} {
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if isFounder();
    }

    match /hub_product/{docId} {
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if isFounder();
    }

    match /hub_team/{docId} {
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if isFounder();
    }

    match /hub_founders_room/{docId} {
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if isFounder();
    }

    match /hub_action_items/{docId} {
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if isFounder();
    }

    // ─── hub_gfm_donors ─────────────────────────────────────────
    // GoFundMe donor records — founder-only read/write.
    // This was previously missing from rules → causing permission errors.
    match /hub_gfm_donors/{docId} {
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if isFounder();
    }

    match /hub_activity/{docId} {
      // Append-only audit log: founders can read + create only
      allow read: if isFounder();
      allow create: if isFounder();
      allow update, delete: if false;
    }

    // ─── Catch-all: deny everything else ────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
