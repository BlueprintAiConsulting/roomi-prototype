rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────

    // True if the request is from an authenticated, non-anonymous user
    function isAuthenticated() {
      return request.auth != null && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    // True if the request is from the document owner
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // True if the user is a caregiver
    function isCaregiver() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/userRoles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/userRoles/$(request.auth.uid)).data.role == 'caregiver';
    }

    // True if caregiver is linked to a specific resident
    function isCaregiverFor(residentUid) {
      return isCaregiver() &&
        exists(/databases/$(database)/documents/userRoles/$(residentUid)) &&
        request.auth.uid in get(/databases/$(database)/documents/userRoles/$(residentUid)).data.get('caregiverUids', []);
    }

    // ─── userRoles ──────────────────────────────────────────────
    // Users can read/write their own role doc.
    // Caregivers can read resident role docs they are linked to.
    match /userRoles/{uid} {
      allow read: if isOwner(uid) || isCaregiver();
      allow create: if isOwner(uid) && isAuthenticated();
      // Only allow updating own doc; prevent self-escalation to caregiver via resident path
      allow update: if isOwner(uid) && isAuthenticated();
      allow delete: if false; // never delete roles
    }

    // ─── users (profiles) ───────────────────────────────────────
    // Residents can only read/write their own profile.
    // Caregivers can read profiles of their residents.
    // Allow any auth (incl. anonymous) to write own profile — full auth required for sensitive ops
    match /users/{uid} {
      allow read: if isOwner(uid) || isCaregiverFor(uid);
      allow write: if isOwner(uid) && request.auth != null;
    }

    // ─── conversations ──────────────────────────────────────────
    // Residents can read/write their own conversations.
    // Caregivers can read their residents' conversations.
    match /conversations/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         isCaregiverFor(resource.data.userId));
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ─── anchorSummaries ────────────────────────────────────────
    // Only authenticated (non-anonymous) residents can write their own.
    // Caregivers can read their residents' summaries.
    match /anchorSummaries/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         isCaregiverFor(resource.data.userId));
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ─── dailySummaries (cross-session memory) ────────────────
    // Residents can read/write their own daily summaries.
    // Caregivers can read their residents' summaries.
    match /dailySummaries/{docId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         isCaregiverFor(resource.data.userId));
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ─── fcmTokens ──────────────────────────────────────────────
    // Users manage their own push tokens only.
    match /fcmTokens/{uid} {
      allow read, write: if isOwner(uid) && isAuthenticated();
    }

    // ─── analytics (Phase 1) ────────────────────────────────────
    // Write-only from client — no userId field (hashed), so no owner check possible.
    // Read only via Firebase Admin SDK (console / backend). Never expose to client.
    match /analytics/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ─── feedback (Phase 1) ─────────────────────────────────────
    // Write-only from client. Reads reserved for admin review.
    match /feedback/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ─── safetyEvents (Phase 1) ─────────────────────────────────
    // Write-only from client. Critical for safety monitoring.
    // Read only via admin. No client read ever.
    match /safetyEvents/{docId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false;
    }

    // ─── Catch-all: deny everything else ────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
